{
	"name": "remix-v3-alpha-4",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n server,browser -c magenta,cyan \"NODE_ENV=development tsx watch src/server.tsx\" \"esbuild src/entry.tsx src/components/Counter.tsx src/components/ActivityPanel.tsx --outdir=public/assets --bundle --splitting --format=esm --sourcemap --watch\"",
		"build": "tsc --noEmit && esbuild src/entry.tsx src/components/Counter.tsx src/components/ActivityPanel.tsx --outdir=public/assets --bundle --splitting --format=esm --sourcemap --minify",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"concurrently": "^9.2.1",
		"remix": "3.0.0-alpha.4",
		"tsx": "^4.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "^25.5.2",
		"esbuild": "^0.25.0",
		"typescript": "~5.9.3"
	}
}
