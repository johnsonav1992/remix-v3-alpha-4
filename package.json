		"format": "biome format --write ."
	},
	"dependencies": {
		"concurrently": "^9.2.1",
		"remix": "3.0.0-alpha.4",
		"tsx": "^4.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "^25.5.2",
		"typescript": "~5.9.3",
		"vite": "^8.0.3"
	}
}
