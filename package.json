{
	"name": "remix-v3-alpha-4",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n vite,server -c cyan,magenta \"vite\" \"NODE_ENV=development tsx watch src/server.tsx\"",
		"build": "tsc && vite build",
